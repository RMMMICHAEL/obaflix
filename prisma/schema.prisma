generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Filme {
  id               String        @id
  tmdbId           String?
  imdbId           String?
  titulo           String
  tituloOriginal   String?
  poster           String?
  background       String?
  logo             String?
  sinopse          String?       @db.Text
  ano              Int?
  nota             Float?
  voteCount        Int?
  popularidade     Float?
  scoreDestaque    Float?
  duracao          Int?
  top250           Int?
  top250Fonte          String?
  top250AtualizadoEm   DateTime?
  popularRank          Int?
  popularRankPrev      Int?
  popularCheckedAt     DateTime?
  sagaId           Int?
  originalLanguage String?
  urlDub           String?       @db.Text
  urlLeg           String?       @db.Text
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  generos          FilmeGenero[]
  progresso        WatchHistory[]
  watchlist        Watchlist[]
}

model Serie {
  id             String        @id
  tmdbId         String?
  imdbId         String?
  titulo         String
  tituloOriginal String?
  poster         String?
  background     String?
  logo           String?
  sinopse        String?       @db.Text
  ano            Int?
  nota           Float?
  voteCount        Int?
  popularidade     Float?
  scoreDestaque    Float?
  temporadas     Int?
  top250           Int?
  top250Fonte          String?
  top250AtualizadoEm   DateTime?
  popularRank          Int?
  popularRankPrev      Int?
  popularCheckedAt     DateTime?
  tipo             String        @default("serie")
  originalLanguage String?
  createdAt        DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  episodios      Episodio[]
  generos        SerieGenero[]
  progresso      WatchHistory[]
  watchlist      Watchlist[]
}

model Episodio {
  id        String        @id
  serieId   String
  serie     Serie         @relation(fields: [serieId], references: [id])
  numeroEp  Int
  temporada Int
  titulo    String?
  thumbnail String?
  urlDub    String?       @db.Text
  urlLeg    String?       @db.Text
  createdAt DateTime      @default(now())
  progresso WatchHistory[]

  @@unique([serieId, temporada, numeroEp])
}

model Genero {
  id     Int           @id
  nome   String
  filmes FilmeGenero[]
  series SerieGenero[]
}

model FilmeGenero {
  filmeId  String
  generoId Int
  filme    Filme  @relation(fields: [filmeId], references: [id])
  genero   Genero @relation(fields: [generoId], references: [id])
  @@id([filmeId, generoId])
}

model SerieGenero {
  serieId  String
  generoId Int
  serie    Serie  @relation(fields: [serieId], references: [id])
  genero   Genero @relation(fields: [generoId], references: [id])
  @@id([serieId, generoId])
}

model User {
  id        String         @id @default(cuid())
  nome      String?
  email     String         @unique
  senhaHash String?
  avatar    String?
  role      String         @default("user")
  createdAt DateTime       @default(now())
  historico WatchHistory[]
  watchlist Watchlist[]
  likes     Like[]
}

model Like {
  id           String   @id @default(cuid())
  userId       String
  conteudoId   String
  conteudoTipo String
  valor        Int
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, conteudoId, conteudoTipo])
}

model WatchHistory {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  conteudoId   String
  conteudoTipo String
  episodioId   String?
  episodio     Episodio? @relation(fields: [episodioId], references: [id])
  temporada    Int?
  numeroEp     Int?
  progressoSeg Int       @default(0)
  duracaoSeg   Int?
  concluido    Boolean   @default(false)
  queued       Boolean   @default(false)
  updatedAt    DateTime  @updatedAt
  filmeId      String?
  filme        Filme?    @relation(fields: [filmeId], references: [id])
  serieId      String?
  serie        Serie?    @relation(fields: [serieId], references: [id])
  @@unique([userId, conteudoId, episodioId])
}

model Watchlist {
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  conteudoId   String
  conteudoTipo String
  addedAt      DateTime @default(now())
  filmeId      String?
  filme        Filme?   @relation(fields: [filmeId], references: [id])
  serieId      String?
  serie        Serie?   @relation(fields: [serieId], references: [id])
  @@id([userId, conteudoId, conteudoTipo])
}

model Saga {
  id   Int    @id
  nome String
}

model PopularHistory {
  id           String   @id @default(cuid())
  conteudoId   String
  conteudoTipo String   // "filme" | "serie"
  rank         Int
  recordedAt   DateTime @default(now())

  @@index([conteudoId, conteudoTipo])
}

model SyncMetric {
  id               String   @id @default(cuid())
  job              String   // "popular-sync"
  source           String   // "tmdb"
  startedAt        DateTime @default(now())
  durationMs       Int
  found            Int
  added            Int
  removed          Int
  repositioned     Int
  bytesTransferred Int?
  errors           Int
  ok               Boolean
  errorMessage     String?  @db.Text
  detail           String?  @db.Text
}
